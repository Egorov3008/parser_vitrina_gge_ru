# Авторизация на портале
VITRINA_URL=https://vitrina.gge.ru
VITRINA_LOGIN=your_login@example.com
VITRINA_PASSWORD=your_password

# Telegram
TELEGRAM_BOT_TOKEN=1234567890:AAExampleToken
TELEGRAM_CHAT_ID=-1001234567890

# Фильтры (JSON массивы)
FILTER_CATEGORIES=["Жилые здания","Административные здания"]
FILTER_REGIONS=["Москва","Московская область"]

# Расписание (cron, UTC)
CRON_SCHEDULE=0 6 * * *

# База данных
DB_PATH=./data/vitrina.db

# Запустить немедленно при старте
RUN_ON_START=false

# Браузер
HEADLESS=true

# Администраторы бота (список Telegram ID через запятую)
# Узнать ID можно через бота @userinfobot
ADMIN_ID=123456789,987654321

# Логирование
LOG_LEVEL=INFO
LOG_DIR=./logs
